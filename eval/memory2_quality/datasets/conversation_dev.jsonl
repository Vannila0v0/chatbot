{"case_id":"conv_dev_food_preference_update_001","category":"history_current_conflict","description":"用户从一次方便食品选择中澄清真正的长期食物偏好","source":"sanitized_daily_conversation","reference_time":"2026-04-08T20:00:00+08:00","initial_memories":[{"local_id":"old_food","memory_type":"preference","summary":"用户喜欢饺子","status":"active"}],"sessions":[{"session_id":"food_s1","timestamp":"2026-04-01T19:00:00+08:00","messages":[{"role":"user","content":"今晚不知道吃什么，想选个省事的。"},{"role":"assistant","content":"可以买点速冻食品，准备起来比较方便。"},{"role":"user","content":"那我吃饺子吧，虽然稍微有点贵。"}],"consolidate_after":true},{"session_id":"food_s2","timestamp":"2026-04-08T20:00:00+08:00","messages":[{"role":"assistant","content":"上次你吃了饺子，最近还想吃类似的吗？"},{"role":"user","content":"其实我并不喜欢饺子，上次只是图方便。我长期更喜欢海鲜和火锅。"},{"role":"assistant","content":"明白，方便时吃饺子不代表它是你的长期偏好。"}],"consolidate_after":true}],"expected_write":{"required":[{"label":"current_food_preference","memory_type":"preference","facts":["用户长期更喜欢海鲜和火锅"]}],"forbidden":[{"facts":["用户喜欢饺子"]}],"expected_actions":[{"target_local_id":"old_food","action":"supersede"}],"allowed_new_count":{"min":1,"max":1}},"recall_probes":[{"probe_id":"food_implicit","query":"以后给我推荐聚餐食物时，优先考虑哪一类？","top_k":3,"required_memory_labels":["current_food_preference"],"forbidden_local_ids":["old_food"]}],"tags":["topic:food_preference_update","preference_update","multi_session"]}
{"case_id":"conv_dev_job_company_criteria_001","category":"noise_extraction","description":"用户在讨论企业时逐步澄清自己真正重视的求职评价标准","source":"sanitized_daily_conversation","reference_time":"2026-04-12T15:00:00+08:00","initial_memories":[],"sessions":[{"session_id":"criteria_s1","timestamp":"2026-04-10T14:00:00+08:00","messages":[{"role":"user","content":"看到一家公司的岗位，但网上对它的品牌评价不太一致。"},{"role":"assistant","content":"你会更在意它是不是大型企业，或者外界口碑吗？"},{"role":"user","content":"这些可以参考，但不是我决定投不投的核心。"}],"consolidate_after":true},{"session_id":"criteria_s2","timestamp":"2026-04-12T15:00:00+08:00","messages":[{"role":"assistant","content":"那筛选公司时，什么因素对你最重要？"},{"role":"user","content":"我主要关心员工待遇、工作强度和团队对员工怎么样，企业所有制和消费者评价不是重点。"},{"role":"assistant","content":"以后分析岗位时应优先看雇佣体验和实际待遇。"}],"consolidate_after":true}],"expected_write":{"required":[{"label":"company_evaluation_priority","memory_type":"preference","facts":["用户评价求职公司时优先关注员工待遇、工作强度和雇佣体验"]}],"forbidden":[{"facts":["用户求职时最看重企业所有制"]},{"facts":["用户主要依据消费者口碑选择公司"]}],"allowed_new_count":{"min":1,"max":1}},"recall_probes":[{"probe_id":"criteria_implicit","query":"帮我判断一个岗位值不值得投时，应该优先调查哪些方面？","top_k":3,"required_memory_labels":["company_evaluation_priority"],"forbidden_facts":["用户求职时最看重企业所有制"]}],"tags":["topic:job_company_criteria","preference","multi_session"]}
{"case_id":"conv_dev_mouse_constraints_001","category":"noise_extraction","description":"从多轮购买讨论中形成带条件的设备偏好","source":"sanitized_daily_conversation","reference_time":"2026-04-15T18:00:00+08:00","initial_memories":[],"sessions":[{"session_id":"mouse_s1","timestamp":"2026-04-14T17:00:00+08:00","messages":[{"role":"user","content":"现在的鼠标最近不太稳定，我可能会换一个。"},{"role":"assistant","content":"你更看重性能、重量还是握持感？"},{"role":"user","content":"我的手比较小，所以模具是否适合小手最重要。"}],"consolidate_after":true},{"session_id":"mouse_s2","timestamp":"2026-04-15T18:00:00+08:00","messages":[{"role":"assistant","content":"预算和性能方面有什么要求？"},{"role":"user","content":"预算大概一两百元，不追求很高配置，只要小手握着舒服就行。"},{"role":"assistant","content":"那推荐时应把小尺寸和预算放在高性能之前。"}],"consolidate_after":true}],"expected_write":{"required":[{"label":"mouse_purchase_constraints","memory_type":"preference","facts":["用户选购鼠标时优先考虑适合小手的模具，预算约一两百元，不追求高性能"]}],"forbidden":[{"facts":["用户选购鼠标时最看重高性能"]}],"allowed_new_count":{"min":1,"max":1}},"recall_probes":[{"probe_id":"mouse_recommendation","query":"下次给我挑鼠标，最关键的筛选条件是什么？","top_k":3,"required_memory_labels":["mouse_purchase_constraints"]}],"tags":["topic:mouse_purchase_constraints","conditional_preference","multi_session"]}
{"case_id":"conv_dev_temporary_sleep_plan_001","category":"temporary_state","description":"短期作息尝试不能被写成稳定生活习惯","source":"sanitized_daily_conversation","reference_time":"2026-04-20T23:30:00+08:00","initial_memories":[],"sessions":[{"session_id":"sleep_s1","timestamp":"2026-04-19T21:00:00+08:00","messages":[{"role":"user","content":"我最近想试着早点睡，今天争取十二点前上床。"},{"role":"assistant","content":"这是长期作息调整，还是先试一两天？"},{"role":"user","content":"先试试，还不确定能不能坚持。"}],"consolidate_after":true},{"session_id":"sleep_s2","timestamp":"2026-04-20T23:30:00+08:00","messages":[{"role":"assistant","content":"今天还准备继续早睡吗？"},{"role":"user","content":"今晚可能还是会晚一点，之前只是一次尝试。"}],"consolidate_after":true}],"expected_write":{"required":[],"forbidden":[{"facts":["用户长期坚持十二点前睡觉"]},{"facts":["用户具有稳定早睡习惯"]}],"allowed_new_count":{"min":0,"max":0}},"recall_probes":[{"probe_id":"sleep_negative","query":"用户有什么已经确定的长期作息习惯？","top_k":3,"forbidden_facts":["用户长期坚持十二点前睡觉","用户具有稳定早睡习惯"]}],"tags":["topic:temporary_sleep_plan","temporary_state","negative_write","multi_session"]}
{"case_id":"conv_dev_expired_reminder_001","category":"temporary_state","description":"前一天的提醒安排在时间过去后不应成为长期规则","source":"sanitized_daily_conversation","reference_time":"2026-04-23T16:00:00+08:00","initial_memories":[],"sessions":[{"session_id":"reminder_s1","timestamp":"2026-04-22T10:00:00+08:00","messages":[{"role":"user","content":"今天晚上八点提醒我练习算法题。"},{"role":"assistant","content":"好的，这是仅限今天的一次提醒。"}],"consolidate_after":true},{"session_id":"reminder_s2","timestamp":"2026-04-23T14:00:00+08:00","messages":[{"role":"assistant","content":"要继续沿用昨晚的算法题安排吗？"},{"role":"user","content":"不用，那是昨天的一次性计划。今天如果安排，就改成下午三点。"},{"role":"assistant","content":"明白，昨天的时间不能当作固定习惯。"}],"consolidate_after":true},{"session_id":"reminder_s3","timestamp":"2026-04-23T16:00:00+08:00","messages":[{"role":"user","content":"下午的事情已经结束了，不要再保留这个提醒。"},{"role":"assistant","content":"好的，这次安排已经过期。"}],"consolidate_after":true}],"expected_write":{"required":[],"forbidden":[{"facts":["用户每天晚上八点练习算法题"]},{"facts":["用户每天三点需要算法题提醒"]}],"allowed_new_count":{"min":0,"max":0}},"recall_probes":[{"probe_id":"reminder_negative","query":"用户是否有固定的每日算法题提醒时间？","top_k":3,"forbidden_facts":["用户每天晚上八点练习算法题","用户每天三点需要算法题提醒"]}],"tags":["topic:expired_reminder","temporary_state","expired_context","multi_session"]}
{"case_id":"conv_dev_job_search_goal_001","category":"noise_extraction","description":"用户经过多轮讨论明确当前求职目标","source":"sanitized_daily_conversation","reference_time":"2026-04-28T17:00:00+08:00","initial_memories":[],"sessions":[{"session_id":"goal_s1","timestamp":"2026-04-25T15:00:00+08:00","messages":[{"role":"user","content":"最近实习岗位似乎变少了，我还在继续找。"},{"role":"assistant","content":"你准备只投实习，还是也开始准备正式招聘？"},{"role":"user","content":"现在还没想清楚，先看看机会。"}],"consolidate_after":true},{"session_id":"goal_s2","timestamp":"2026-04-28T17:00:00+08:00","messages":[{"role":"assistant","content":"结合时间安排，你现在更明确的目标是什么？"},{"role":"user","content":"接下来以准备秋季招聘为主，同时继续关注大模型应用方向的日常实习。"},{"role":"assistant","content":"明白，主线是秋招，合适的日常实习仍然会投。"}],"consolidate_after":true}],"expected_write":{"required":[{"label":"current_job_search_goal","memory_type":"profile","facts":["用户当前以准备秋季招聘为主，同时关注大模型应用方向的日常实习"]}],"forbidden":[{"facts":["用户当前只考虑短期实习"]}],"allowed_new_count":{"min":1,"max":1}},"recall_probes":[{"probe_id":"goal_implicit","query":"接下来为我筛选招聘信息时，主线和补充方向分别是什么？","top_k":3,"required_memory_labels":["current_job_search_goal"]}],"tags":["topic:job_search_goal","profile","multi_session"]}
{"case_id":"conv_dev_model_usage_preference_001","category":"entity_attribute_conflict","description":"区分用户在不同任务中使用模型的条件偏好","source":"sanitized_daily_conversation","reference_time":"2026-05-03T16:00:00+08:00","initial_memories":[],"sessions":[{"session_id":"model_s1","timestamp":"2026-05-01T14:00:00+08:00","messages":[{"role":"user","content":"日常问答我倾向用价格更低的模型，效果对我来说已经够用。"},{"role":"assistant","content":"那写代码时也会使用同一个模型吗？"},{"role":"user","content":"不会，编码任务我通常交给专门的代码助手。"}],"consolidate_after":true},{"session_id":"model_s2","timestamp":"2026-05-03T16:00:00+08:00","messages":[{"role":"assistant","content":"你自己开发 Agent 时，基础模型怎么选？"},{"role":"user","content":"Agent 的基础模型可以用便宜的通用模型，但专业编码还是使用代码助手。"},{"role":"assistant","content":"也就是说你的选择取决于任务类型，而不是统一偏好某个模型。"}],"consolidate_after":true}],"expected_write":{"required":[{"label":"conditional_model_usage","memory_type":"preference","facts":["用户开发Agent时可使用经济的通用模型，专业编码任务优先使用代码助手"]}],"forbidden":[{"facts":["用户所有任务都只使用通用模型"]},{"facts":["用户所有任务都只使用代码助手"]}],"allowed_new_count":{"min":1,"max":1}},"recall_probes":[{"probe_id":"model_task_condition","query":"我做 Agent 和写专业代码时，模型选择有什么不同？","top_k":3,"required_memory_labels":["conditional_model_usage"]}],"tags":["topic:model_usage_preference","conditional_preference","entity_attribute","multi_session"]}
{"case_id":"conv_dev_temporary_job_anxiety_001","category":"temporary_state","description":"求职受挫时的短期情绪不能被固化为长期人格","source":"sanitized_daily_conversation","reference_time":"2026-05-08T21:00:00+08:00","initial_memories":[],"sessions":[{"session_id":"mood_s1","timestamp":"2026-05-07T20:00:00+08:00","messages":[{"role":"user","content":"连续投了不少岗位都没反馈，我今天有点沮丧，感觉努力没有意义。"},{"role":"assistant","content":"长期没有反馈确实容易让人挫败，但这更像当前阶段的情绪。"}],"consolidate_after":true},{"session_id":"mood_s2","timestamp":"2026-05-08T21:00:00+08:00","messages":[{"role":"assistant","content":"今天状态怎么样？"},{"role":"user","content":"好多了，机会还在，接下来继续准备和投递。"},{"role":"assistant","content":"明白，昨天的低落不是稳定的长期状态。"}],"consolidate_after":true}],"expected_write":{"required":[],"forbidden":[{"facts":["用户长期对求职失去信心"]},{"facts":["用户具有悲观人格"]}],"allowed_new_count":{"min":0,"max":0}},"recall_probes":[{"probe_id":"mood_negative","query":"用户有什么确定的长期心理特征？","top_k":3,"forbidden_facts":["用户长期对求职失去信心","用户具有悲观人格"]}],"tags":["topic:temporary_job_anxiety","temporary_state","emotion","multi_session"]}
