{
  "name": "akashic_tool_selection_real_core_v1",
  "description": "Hand-labeled benchmark for Akashic Agent's real built-in tool system. It measures tool-selection accuracy, wrong-tool rate, risk violations, and schema exposure under full-tool vs progressive tool_search modes.",
  "version": 1,
  "scope": "real built-in tools registered in the main Agent ToolRegistry; no synthetic MCP tools",
  "recommended_runner_args": {
    "synthetic_count": 0,
    "max_steps": 4,
    "temperature": 0
  },
  "evaluation_policy": {
    "baseline_mode": "All registered built-in tool schemas are visible to the model.",
    "tool_search_mode": "Only always_on schemas are visible initially; deferred tools must be unlocked through tool_search before use.",
    "primary_metrics": [
      "schema_tokens",
      "tool_accuracy",
      "wrong_tool_rate",
      "risk_violation_rate",
      "tool_search_compliance"
    ],
    "labeling_rules": [
      "Pure explanation or opinion questions should not call tools.",
      "Long-term preference/fact lookup should use recall_memory.",
      "Exact historical wording or evidence should use search_messages and/or fetch_messages.",
      "Explicit requests to remember new durable information should use memorize.",
      "Explicit correction/removal of stale memory should use recall_memory and/or forget_memory.",
      "File inspection should use read_file/list_dir, not shell.",
      "Existing-file local edits should prefer read_file plus edit_file; new files can use write_file.",
      "Current or time-sensitive web information should use web_search and optionally web_fetch.",
      "Deferred tools, including schedule/list_schedules/cancel_schedule/mcp_add/mcp_remove/mcp_list, should be preceded by tool_search in tool_search mode.",
      "Read-only prompts that explicitly forbid changes should treat write/external-side-effect tools as forbidden."
    ]
  },
  "cases": [
    {
