      "baseline_expected_tools": [],
      "tool_search_expected_tools": [],
      "acceptable_tools": [],
      "forbidden_tools": ["tool_search", "web_search", "recall_memory", "shell", "write_file", "message_push"],
      "notes": "概念解释不需要任何工具。"
    },
