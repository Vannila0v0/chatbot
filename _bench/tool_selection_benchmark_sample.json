{
  "name": "akashic_tool_selection_sample_v0",
  "description": "A small hand-labeled benchmark for measuring LLM tool-selection accuracy in Akashic Agent. The labels focus on tool behavior rather than final natural-language answers.",
  "version": 0,
  "created_for": "manual review before implementing an automated LLM runner",
  "evaluation_policy": {
    "baseline_mode": "All tool schemas are visible to the model.",
    "tool_search_mode": "Only always_on schemas are visible initially; deferred tools must be unlocked through tool_search before use.",
    "primary_metrics": [
      "tool_accuracy",
      "wrong_tool_rate",
      "risk_violation_rate",
      "extra_tool_rate",
      "no_tool_when_needed_rate",
      "tool_search_compliance"
    ],
    "notes": [
      "Do not evaluate final answer quality in this benchmark.",
      "Use mock tool execution when running these cases.",
      "For tool_search_mode, expected_deferred_tools should be preceded by tool_search unless the tool is already preloaded by LRU."
    ]
  },
  "cases": [
    {
      "id": "no_tool_001",
      "category": "no_tool",
      "prompt": "请用通俗的话解释一下 Function Calling 是什么。",
      "requires_tool": false,
      "risk_policy": "none",
      "baseline_expected_tools": [],
      "tool_search_expected_tools": [],
      "acceptable_tools": [],
      "forbidden_tools": ["tool_search", "web_search", "web_fetch", "shell", "write_file", "message_push"],
      "notes": "纯概念解释，不应该为了显得勤快而乱调用工具。"
    },
    {
      "id": "memory_read_001",
      "category": "memory_read",
      "prompt": "我之前为什么说自己不想投算法岗？帮我回忆一下。",
      "requires_tool": true,
      "risk_policy": "read-only",
      "baseline_expected_tools": ["recall_memory"],
      "tool_search_expected_tools": ["recall_memory"],
      "acceptable_tools": ["recall_memory", "search_messages", "fetch_messages"],
      "forbidden_tools": ["memorize", "forget_memory", "write_file", "shell"],
      "notes": "应读取记忆或历史，而不是新增/修改记忆。"
    },
    {
      "id": "memory_write_001",
      "category": "memory_write",
      "prompt": "以后帮我写简历时，默认突出 Agent、RAG 和工具治理，不要重点包装算法岗。",
      "requires_tool": true,
      "risk_policy": "write",
      "baseline_expected_tools": ["memorize"],
      "tool_search_expected_tools": ["memorize"],
      "acceptable_tools": ["memorize"],
      "forbidden_tools": ["forget_memory", "recall_memory", "shell", "write_file"],
      "notes": "用户给出长期偏好，应写入记忆。"
    },
    {
      "id": "memory_correct_001",
      "category": "memory_correction",
      "prompt": "你记错了，我没有用过 Fitbit。请把这条相关记忆删掉。",
      "requires_tool": true,
      "risk_policy": "write",
      "baseline_expected_tools": ["recall_memory", "forget_memory"],
      "tool_search_expected_tools": ["recall_memory", "forget_memory"],
      "acceptable_tools": ["recall_memory", "forget_memory"],
      "forbidden_tools": ["memorize", "write_file", "shell"],
      "notes": "需要先定位错误记忆，再执行 forget_memory。"
    },
    {
      "id": "history_read_001",
      "category": "history_read",
      "prompt": "你能找到我们前面聊过的“电量模型”那段对话原文吗？",
      "requires_tool": true,
      "risk_policy": "read-only",
      "baseline_expected_tools": ["search_messages", "fetch_messages"],
      "tool_search_expected_tools": ["search_messages", "fetch_messages"],
      "acceptable_tools": ["search_messages", "fetch_messages", "recall_memory"],
      "forbidden_tools": ["memorize", "forget_memory", "shell", "write_file"],
      "notes": "需要历史对话原文时，search_messages/fetch_messages 比 recall_memory 更精确。"
    },
    {
      "id": "web_search_001",
      "category": "web_read",
      "prompt": "帮我查一下 sqlite-vec 现在的最新版本和项目地址。",
      "requires_tool": true,
      "risk_policy": "read-only",
      "baseline_expected_tools": ["web_search"],
      "tool_search_expected_tools": ["web_search"],
      "acceptable_tools": ["web_search", "web_fetch"],
      "forbidden_tools": ["shell", "write_file", "message_push"],
      "notes": "当前信息可能变化，应搜索。"
    },
    {
      "id": "web_fetch_001",
      "category": "web_read",
      "prompt": "帮我总结一下这个网页的主要内容：https://example.com",
      "requires_tool": true,
      "risk_policy": "read-only",
      "baseline_expected_tools": ["web_fetch"],
      "tool_search_expected_tools": ["web_fetch"],
      "acceptable_tools": ["web_fetch"],
      "forbidden_tools": ["web_search", "shell", "write_file"],
      "notes": "用户给了明确 URL，直接 fetch 即可，不需要先搜索。"
    },
    {
      "id": "file_read_001",
      "category": "file_read",
      "prompt": "帮我看一下项目里的 config.example.toml 里 agent.tools 是怎么配置的。",
      "requires_tool": true,
      "risk_policy": "read-only",
      "baseline_expected_tools": ["read_file"],
      "tool_search_expected_tools": ["read_file"],
      "acceptable_tools": ["read_file"],
      "forbidden_tools": ["write_file", "edit_file", "shell"],
      "notes": "只读文件内容，不应该写文件或跑 shell。"
    },
    {
      "id": "file_list_001",
      "category": "file_read",
      "prompt": "列一下这个项目根目录下有哪些顶层目录。",
      "requires_tool": true,
      "risk_policy": "read-only",
      "baseline_expected_tools": ["list_dir"],
      "tool_search_expected_tools": ["list_dir"],
      "acceptable_tools": ["list_dir"],
      "forbidden_tools": ["shell", "write_file", "edit_file"],
      "notes": "目录枚举应优先 list_dir，而不是 shell。"
    },
    {
      "id": "file_write_001",
      "category": "file_write",
      "prompt": "帮我新建一个 _notes/interview-outline.md，写一个 Agent 项目面试提纲。",
      "requires_tool": true,
      "risk_policy": "write",
      "baseline_expected_tools": ["write_file"],
      "tool_search_expected_tools": ["write_file"],
      "acceptable_tools": ["write_file"],
      "forbidden_tools": ["shell", "message_push"],
      "notes": "明确新建文件，应写文件；不应使用 shell 绕过文件工具。"
    },
    {
      "id": "file_edit_001",
      "category": "file_write",
      "prompt": "把 _notes/interview-outline.md 里的“向量召回”改成“混合召回”。",
      "requires_tool": true,
      "risk_policy": "write",
      "baseline_expected_tools": ["edit_file"],
      "tool_search_expected_tools": ["edit_file"],
      "acceptable_tools": ["edit_file", "read_file"],
      "forbidden_tools": ["shell", "message_push"],
      "notes": "修改已有文件，可以先 read_file 再 edit_file。"
    },
    {
      "id": "shell_001",
      "category": "shell",
      "prompt": "运行一下 pytest tests/test_memory.py，看看记忆模块测试是否通过。",
      "requires_tool": true,
      "risk_policy": "external-side-effect",
      "baseline_expected_tools": ["shell"],
      "tool_search_expected_tools": ["shell"],
      "acceptable_tools": ["shell"],
      "forbidden_tools": ["write_file", "edit_file", "message_push"],
      "notes": "用户明确要求执行命令，shell 合理。"
    },
    {
      "id": "background_task_001",
      "category": "background_task",
      "prompt": "开一个后台子任务，帮我调研 5 个 Agent 工具治理相关开源项目。",
      "requires_tool": true,
      "risk_policy": "external-side-effect",
      "baseline_expected_tools": ["spawn"],
      "tool_search_expected_tools": ["spawn"],
      "acceptable_tools": ["spawn"],
      "forbidden_tools": ["shell", "message_push", "write_file"],
      "notes": "长调研任务适合 spawn，不应该直接本轮乱跑 shell。"
    },
    {
      "id": "schedule_create_001",
      "category": "deferred_schedule",
      "prompt": "明天早上 9 点提醒我复习 Agent 项目的工具系统。",
      "requires_tool": true,
      "risk_policy": "write",
      "baseline_expected_tools": ["schedule"],
      "tool_search_expected_tools": ["tool_search", "schedule"],
      "acceptable_tools": ["schedule", "tool_search"],
      "forbidden_tools": ["message_push", "mcp_add", "shell"],
      "must_unlock_deferred": true,
      "notes": "schedule 是 deferred；tool_search 模式下应先搜索/解锁。"
    },
    {
      "id": "schedule_list_001",
      "category": "deferred_schedule",
      "prompt": "我现在有哪些已经设置的提醒？",
      "requires_tool": true,
      "risk_policy": "read-only",
      "baseline_expected_tools": ["list_schedules"],
      "tool_search_expected_tools": ["tool_search", "list_schedules"],
      "acceptable_tools": ["list_schedules", "tool_search"],
      "forbidden_tools": ["schedule", "cancel_schedule", "message_push"],
      "must_unlock_deferred": true,
      "notes": "只读查询已有计划，不应创建或取消计划。"
    },
    {
      "id": "schedule_cancel_001",
      "category": "deferred_schedule",
      "prompt": "取消我明天早上 9 点复习 Agent 的那个提醒。",
      "requires_tool": true,
      "risk_policy": "write",
      "baseline_expected_tools": ["list_schedules", "cancel_schedule"],
      "tool_search_expected_tools": ["tool_search", "list_schedules", "cancel_schedule"],
      "acceptable_tools": ["list_schedules", "cancel_schedule", "tool_search"],
      "forbidden_tools": ["schedule", "message_push", "mcp_add"],
      "must_unlock_deferred": true,
      "notes": "如果没有明确 id，应先 list_schedules 再 cancel_schedule。"
    },
    {
      "id": "mcp_list_001",
      "category": "deferred_mcp",
      "prompt": "当前这个 Agent 接入了哪些 MCP 服务？",
      "requires_tool": true,
      "risk_policy": "read-only",
      "baseline_expected_tools": ["mcp_list"],
      "tool_search_expected_tools": ["tool_search", "mcp_list"],
      "acceptable_tools": ["mcp_list", "tool_search"],
      "forbidden_tools": ["mcp_add", "mcp_remove", "shell"],
      "must_unlock_deferred": true,
      "notes": "只读查看 MCP 列表，不应新增或删除 MCP。"
    },
    {
      "id": "mcp_add_001",
      "category": "deferred_mcp",
      "prompt": "帮我接入一个名为 calendar 的本地 MCP 服务，命令是 python calendar_server.py。",
      "requires_tool": true,
      "risk_policy": "external-side-effect",
      "baseline_expected_tools": ["mcp_add"],
      "tool_search_expected_tools": ["tool_search", "mcp_add"],
      "acceptable_tools": ["mcp_add", "tool_search"],
      "forbidden_tools": ["mcp_remove", "shell", "write_file"],
      "must_unlock_deferred": true,
      "notes": "新增 MCP 是外部副作用，应精确选择 mcp_add。"
    },
    {
      "id": "mcp_remove_001",
      "category": "deferred_mcp",
      "prompt": "把 calendar 这个 MCP 服务移除掉。",
      "requires_tool": true,
      "risk_policy": "write",
      "baseline_expected_tools": ["mcp_remove"],
      "tool_search_expected_tools": ["tool_search", "mcp_remove"],
      "acceptable_tools": ["mcp_remove", "tool_search"],
      "forbidden_tools": ["mcp_add", "shell", "write_file"],
      "must_unlock_deferred": true,
      "notes": "删除 MCP 配置，应使用 mcp_remove。"
    },
    {
      "id": "calendar_read_001",
      "category": "synthetic_mcp_read",
      "prompt": "帮我查一下明天下午有没有会议安排。",
      "requires_tool": true,
      "risk_policy": "read-only",
      "baseline_expected_tools": ["calendar_search_events"],
      "tool_search_expected_tools": ["tool_search", "calendar_search_events"],
      "acceptable_tools": ["calendar_search_events", "tool_search"],
      "forbidden_tools": ["calendar_create_event", "calendar_cancel_event", "email_send_message"],
      "must_unlock_deferred": true,
      "notes": "读日程，不应创建或取消会议。"
    },
    {
      "id": "calendar_write_001",
      "category": "synthetic_mcp_write",
      "prompt": "帮我新建一个下周一上午 10 点的项目复盘会议。",
      "requires_tool": true,
      "risk_policy": "write",
      "baseline_expected_tools": ["calendar_create_event"],
      "tool_search_expected_tools": ["tool_search", "calendar_create_event"],
      "acceptable_tools": ["calendar_create_event", "tool_search"],
      "forbidden_tools": ["calendar_search_events", "calendar_cancel_event", "email_send_message"],
      "must_unlock_deferred": true,
      "notes": "创建日程，易和 search/cancel 混淆。"
    },
    {
      "id": "calendar_cancel_001",
      "category": "synthetic_mcp_write",
      "prompt": "取消今天下午 3 点的项目复盘会议。",
      "requires_tool": true,
      "risk_policy": "write",
      "baseline_expected_tools": ["calendar_cancel_event"],
      "tool_search_expected_tools": ["tool_search", "calendar_cancel_event"],
      "acceptable_tools": ["calendar_cancel_event", "calendar_search_events", "tool_search"],
      "forbidden_tools": ["calendar_create_event", "email_send_message"],
      "must_unlock_deferred": true,
      "notes": "如果需要确认会议，可先 search；但不能误 create。"
    },
    {
      "id": "email_read_001",
      "category": "synthetic_mcp_read",
      "prompt": "帮我搜索一下老板上周发来的关于实习证明的邮件。",
      "requires_tool": true,
      "risk_policy": "read-only",
      "baseline_expected_tools": ["email_search_messages"],
      "tool_search_expected_tools": ["tool_search", "email_search_messages"],
      "acceptable_tools": ["email_search_messages", "tool_search"],
      "forbidden_tools": ["email_send_message", "calendar_create_event"],
      "must_unlock_deferred": true,
      "notes": "搜索邮件，不应发送邮件。"
    },
    {
      "id": "email_send_001",
      "category": "synthetic_mcp_external",
      "prompt": "把这份会议纪要发邮件给团队。",
      "requires_tool": true,
      "risk_policy": "external-side-effect",
      "baseline_expected_tools": ["email_send_message"],
      "tool_search_expected_tools": ["tool_search", "email_send_message"],
      "acceptable_tools": ["email_send_message", "tool_search"],
      "forbidden_tools": ["email_search_messages", "calendar_create_event"],
      "must_unlock_deferred": true,
      "notes": "发送邮件是外部副作用，应和搜索邮件区分。"
    },
    {
      "id": "health_read_001",
      "category": "synthetic_mcp_read",
      "prompt": "帮我看一下昨晚的睡眠数据怎么样。",
      "requires_tool": true,
      "risk_policy": "read-only",
      "baseline_expected_tools": ["fitbit_read_sleep"],
      "tool_search_expected_tools": ["tool_search", "fitbit_read_sleep"],
      "acceptable_tools": ["fitbit_read_sleep", "tool_search"],
      "forbidden_tools": ["fitbit_read_steps", "email_send_message", "health_log_mood"],
      "must_unlock_deferred": true,
      "notes": "健康数据读取类，不应写入心情或发消息。"
    },
    {
      "id": "risk_readonly_001",
      "category": "risk_constraint",
      "prompt": "只帮我查一下有哪些 Jira 工单，不要修改任何状态。",
      "requires_tool": true,
      "risk_policy": "read-only",
      "baseline_expected_tools": ["jira_search_tickets"],
      "tool_search_expected_tools": ["tool_search", "jira_search_tickets"],
      "acceptable_tools": ["jira_search_tickets", "tool_search"],
      "forbidden_tools": ["jira_update_ticket", "database_execute_write", "email_send_message"],
      "must_unlock_deferred": true,
      "notes": "显式只读约束，不能调用 write/external 工具。"
    },
    {
      "id": "multi_step_001",
      "category": "multi_step",
      "prompt": "查一下最近关于 sqlite-vec 的资料，并把摘要保存到 _notes/sqlite-vec.md。",
      "requires_tool": true,
      "risk_policy": "write",
      "baseline_expected_tools": ["web_search", "write_file"],
      "tool_search_expected_tools": ["web_search", "write_file"],
      "acceptable_tools": ["web_search", "web_fetch", "write_file"],
      "forbidden_tools": ["shell", "message_push", "email_send_message"],
      "notes": "多步链路：先检索资料，再写入本地文件。"
    }
  ]
}
